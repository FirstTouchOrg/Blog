---
import BaseLayout from '@layouts/BaseLayout.astro';
import type { Locale } from '@i18n/translations';

const locale: Locale = 'zh';
---

<BaseLayout locale={locale} path="/growth-tools" title="增长工具 | LevelUp 博客">
  <section class="space-y-6">
    <h1 class="text-3xl font-bold tracking-tight">增长工具</h1>
    <p class="max-w-2xl text-muted-foreground">
      面向增长与社区运营的实用工具。
    </p>

    <div class="grid gap-4 sm:grid-cols-2 lg:max-w-3xl">
      <a
        href="/zh/growth-tools/utm-url-builder"
        class="rounded-xl border border-[var(--color-border)] bg-card p-5 transition hover:border-[var(--color-gold)] hover:shadow-sm"
      >
        <h2 class="text-lg font-semibold">Quest 渠道链接构造器</h2>
        <p class="mt-2 text-sm text-muted-foreground">
          规范生成 Quest 活动追踪链接：invitecode/ref 固定在最前，UTM 参数自动规范化。
        </p>
      </a>
    </div>
  </section>
</BaseLayout>
