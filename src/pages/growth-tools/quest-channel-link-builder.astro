---
import BaseLayout from '@layouts/BaseLayout.astro';
import type { Locale } from '@i18n/translations';

const locale: Locale = 'en';
---

<BaseLayout
  locale={locale}
  path="/growth-tools/quest-channel-link-builder"
  title="Quest 渠道链接构造器 | Growth Tools"
>
  <section class="mx-auto max-w-3xl space-y-8">
    <header class="space-y-3">
      <h1 class="text-3xl font-bold tracking-tight">Quest 渠道链接构造器</h1>
      <p class="text-sm text-muted-foreground">
        生成规则：<code>invitecode</code> 和 <code>ref</code> 必须固定在前面；
        <code>invitecode</code> 自动大写，其余参数自动小写并将空格替换为 <code>_</code>。
      </p>
    </header>

    <form id="builder-form" class="space-y-6 rounded-xl border border-[var(--color-border)] bg-card p-6">
      <div class="space-y-2">
        <label for="baseUrl" class="text-sm font-semibold">Base URL</label>
        <input
          id="baseUrl"
          name="baseUrl"
          type="url"
          required
          placeholder="https://levelup.land/quest/ANOME-ONE-x9I7n"
          class="w-full rounded-lg border border-[var(--color-border)] bg-background px-3 py-2 text-sm outline-none ring-0 focus:border-[var(--color-gold)]"
        />
        <div class="flex flex-wrap items-center gap-2 text-xs">
          <span class="text-muted-foreground">推荐：</span>
          <button
            type="button"
            data-fill-base="https://levelup.land/quest/ANOME-ONE-x9I7n"
            class="rounded-full border border-[var(--color-border)] px-3 py-1 hover:border-[var(--color-gold)]"
          >
            ANOME One Quest
          </button>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="space-y-2">
          <label for="invitecode" class="text-sm font-semibold">invitecode *</label>
          <input id="invitecode" name="invitecode" required placeholder="ABC123" class="w-full rounded-lg border border-[var(--color-border)] bg-background px-3 py-2 text-sm outline-none focus:border-[var(--color-gold)]" />
        </div>
        <div class="space-y-2">
          <label for="ref" class="text-sm font-semibold">ref *</label>
          <input id="ref" name="ref" required placeholder="vn / anome / kol_alice" class="w-full rounded-lg border border-[var(--color-border)] bg-background px-3 py-2 text-sm outline-none focus:border-[var(--color-gold)]" />
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="space-y-2">
          <label for="utmSource" class="text-sm font-semibold">utm_source *</label>
          <select id="utmSource" name="utmSource" required class="w-full rounded-lg border border-[var(--color-border)] bg-background px-3 py-2 text-sm outline-none focus:border-[var(--color-gold)]">
            <option value="telegram">telegram</option>
            <option value="twitter">twitter</option>
            <option value="discord">discord</option>
            <option value="debox">debox</option>
            <option value="zalo">zalo</option>
            <option value="other">other</option>
          </select>
        </div>
        <div class="space-y-2">
          <label for="utmMedium" class="text-sm font-semibold">utm_medium（自动推断）</label>
          <input id="utmMedium" name="utmMedium" readonly class="w-full rounded-lg border border-[var(--color-border)] bg-muted px-3 py-2 text-sm" />
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="space-y-2">
          <label for="utmCampaign" class="text-sm font-semibold">utm_campaign（可选）</label>
          <input id="utmCampaign" name="utmCampaign" placeholder="vn_recharge_0313" class="w-full rounded-lg border border-[var(--color-border)] bg-background px-3 py-2 text-sm outline-none focus:border-[var(--color-gold)]" />
        </div>
        <div class="space-y-2">
          <label for="utmContent" class="text-sm font-semibold">utm_content（可选）</label>
          <input id="utmContent" name="utmContent" placeholder="banner_v1" class="w-full rounded-lg border border-[var(--color-border)] bg-background px-3 py-2 text-sm outline-none focus:border-[var(--color-gold)]" />
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <button type="submit" class="rounded-lg bg-[var(--color-gold)] px-4 py-2 text-sm font-semibold text-white hover:brightness-110">生成链接</button>
        <button id="copy-btn" type="button" class="rounded-lg border border-[var(--color-border)] px-4 py-2 text-sm font-semibold hover:border-[var(--color-gold)]">复制结果</button>
      </div>
    </form>

    <section class="space-y-4 rounded-xl border border-[var(--color-border)] bg-card p-6">
      <h2 class="text-xl font-semibold">生成结果</h2>
      <pre id="result" class="overflow-x-auto rounded-lg bg-background p-4 text-sm">（点击“生成链接”后显示）</pre>
      <div class="overflow-x-auto">
        <table class="min-w-full text-left text-sm">
          <thead class="text-muted-foreground">
            <tr>
              <th class="py-2 pr-4">参数</th>
              <th class="py-2 pr-4">值</th>
            </tr>
          </thead>
          <tbody id="param-table"></tbody>
        </table>
      </div>
    </section>
  </section>

  <script is:inline>
    const mediumMap = {
      telegram: 'community',
      discord: 'community',
      zalo: 'community',
      twitter: 'social',
      debox: 'social',
      other: 'social'
    };

    const form = document.getElementById('builder-form');
    const sourceEl = document.getElementById('utmSource');
    const mediumEl = document.getElementById('utmMedium');
    const resultEl = document.getElementById('result');
    const tableEl = document.getElementById('param-table');
    const copyBtn = document.getElementById('copy-btn');
    const baseUrlEl = document.getElementById('baseUrl');

    const normalizeLower = (v) => v.trim().toLowerCase().replace(/\s+/g, '_');
    const normalizeUpper = (v) => normalizeLower(v).toUpperCase();

    const updateMedium = () => {
      const value = sourceEl.value || 'other';
      mediumEl.value = mediumMap[value] || 'social';
    };

    updateMedium();
    sourceEl.addEventListener('change', updateMedium);

    document.querySelectorAll('[data-fill-base]').forEach((btn) => {
      btn.addEventListener('click', () => {
        baseUrlEl.value = btn.getAttribute('data-fill-base') || '';
      });
    });

    let latestLink = '';

    form.addEventListener('submit', (event) => {
      event.preventDefault();

      const fd = new FormData(form);
      const baseUrl = String(fd.get('baseUrl') || '').trim();
      const invitecode = normalizeUpper(String(fd.get('invitecode') || ''));
      const ref = normalizeLower(String(fd.get('ref') || ''));
      const utmSource = normalizeLower(String(fd.get('utmSource') || ''));
      const utmMedium = normalizeLower(String(mediumEl.value || 'social'));
      const utmCampaignRaw = String(fd.get('utmCampaign') || '').trim();
      const utmContentRaw = String(fd.get('utmContent') || '').trim();
      const utmCampaign = utmCampaignRaw ? normalizeLower(utmCampaignRaw) : '';
      const utmContent = utmContentRaw ? normalizeLower(utmContentRaw) : '';

      const params = new URLSearchParams();
      params.append('invitecode', invitecode);
      params.append('ref', ref);
      params.append('utm_source', utmSource);
      params.append('utm_medium', utmMedium);
      if (utmCampaign) params.append('utm_campaign', utmCampaign);
      if (utmContent) params.append('utm_content', utmContent);

      latestLink = `${baseUrl}?${params.toString()}`;
      resultEl.textContent = latestLink;

      const rows = [
        ['invitecode', invitecode],
        ['ref', ref],
        ['utm_source', utmSource],
        ['utm_medium', utmMedium],
        ['utm_campaign', utmCampaign || '—'],
        ['utm_content', utmContent || '—']
      ];

      tableEl.innerHTML = rows
        .map(([k, v]) => `<tr><td class="py-1 pr-4 text-muted-foreground">${k}</td><td class="py-1 pr-4 font-mono">${v}</td></tr>`)
        .join('');
    });

    copyBtn.addEventListener('click', async () => {
      if (!latestLink) return;
      try {
        await navigator.clipboard.writeText(latestLink);
        copyBtn.textContent = '已复制';
        setTimeout(() => (copyBtn.textContent = '复制结果'), 1200);
      } catch {
        copyBtn.textContent = '复制失败';
        setTimeout(() => (copyBtn.textContent = '复制结果'), 1200);
      }
    });
  </script>
</BaseLayout>
