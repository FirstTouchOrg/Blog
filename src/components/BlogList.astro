---
import type { CollectionEntry } from 'astro:content';
import { getTranslations, type Locale } from '@i18n/translations';
import { localizedPath } from '@i18n/routing';

interface Props {
  locale: Locale;
  posts: CollectionEntry<'blog'>[];
}

const { locale, posts } = Astro.props as Props;
const t = getTranslations(locale);
const formatter = new Intl.DateTimeFormat(locale === 'zh' ? 'zh-TW' : 'en-US', { dateStyle: 'long' });
---

<section>
  <!-- Page header -->
  <header class="border-b border-[var(--color-border)] pb-8">
    <p class="text-[0.6rem] font-semibold uppercase text-gold">LevelUp Platform</p>
    <h1 class="mt-3 font-display text-4xl font-bold sm:text-5xl">{t.posts.title}</h1>
    <p class="mt-3 max-w-xl text-base text-muted-foreground">{t.meta.description}</p>
  </header>

  <!-- Article index -->
  <div class="divide-y divide-[var(--color-border)]">
    {posts.map((post, i) => (
      <a
        href={localizedPath(locale, `/blog/${post.slug}`)}
        class="article-row group flex items-start gap-6 py-8 transition-all"
      >
        <!-- Issue number -->
        <span class="hidden font-display text-4xl font-bold text-gold/30 transition-colors group-hover:text-gold sm:block">
          {String(i + 1).padStart(2, '0')}
        </span>

        <!-- Content -->
        <div class="flex-1">
          <div class="flex flex-wrap items-center gap-3 text-[0.6rem] font-semibold uppercase text-muted-foreground">
            <time>{formatter.format(post.data.publishDate)}</time>
            {post.data.tags.length > 0 && (
              <>
                <span class="h-0.5 w-0.5 rounded-full bg-muted-foreground"></span>
                {post.data.tags.map((tag: string) => (
                  <span>{tag}</span>
                ))}
              </>
            )}
          </div>
          <h2 class="mt-2 font-display text-2xl font-semibold transition-colors group-hover:text-gold sm:text-3xl">
            {post.data.title}
          </h2>
          <p class="mt-2 max-w-2xl text-sm text-muted-foreground line-clamp-2">
            {post.data.description}
          </p>
        </div>

        <!-- Arrow -->
        <span class="mt-3 hidden text-lg text-muted-foreground transition-all group-hover:translate-x-1 group-hover:text-gold sm:block">→</span>
      </a>
    ))}
  </div>
</section>
